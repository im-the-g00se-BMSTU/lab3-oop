  <property name="styleSheet">
   <string notr="true">QMainWindow {
        background-color: #1e1e1e;
    }
    QLineEdit {
        background-color: #252526;
        color: white;
        border: none;
        font-size: 24px;
    }
QPushButton {
    background-color: #2b2b2b;
    color: #e0e0e0;
    border: 2px solid #3f3f3f;
    border-radius: 15px; /* Скругленные углы */
}

QPushButton:hover {
    background-color: #3d3d3d;
    border: 2px solid #505050;
}

QPushButton:pressed {
    background-color: #1a1a1a;
    border: 2px solid #00ff88;
    color: #00ff88;
}
QPushButton:hover {
    border: 1px solid #00ffcc; 
    background-color: qlineargradient(spread:pad, x1:0.5, y1:0, x2:0.5, y2:1, 
                                      stop:0 #444444, stop:0.5 #3d5a5a, stop:1 #2b2b2b);
}
QPushButton {
    /* Основной фон с легким радиальным градиентом (центр светлее краев) */
    background-color: qradialgradient(spread:pad, cx:0.5, cy:0.5, radius:0.8, fx:0.5, fy:0.5, 
                                      stop:0 #3d3d3d, stop:1 #252525);
    
    /* Цвет текста сделаем чуть ярче, чтобы он &quot;светился&quot; */
    color: #00ffcc; 
    
    /* Яркая рамка создает эффект свечения контура */
    border: 1px solid #008877; 
    border-radius: 12px;
    
    /* Внутренние отступы, чтобы текст не прилипал к краям */
    padding: 5px;
}</string>
